{
  "name": "notification-service",
  "version": "1.0.0",
  "description": "High-Performance Notification Service API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
